# Local development environment for VrBook.
# Copy to .env (which is gitignored) and fill in real values for any external service
# you actually want to test. The docker-compose defaults work as-is.

# ===== Docker compose targets =====
COMPOSE_PROJECT_NAME=vrbook-dev

# ===== Backend (read by VrBook.Api and VrBook.Migrator) =====
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=vrbook;Username=vrbook;Password=vrbook;Include Error Detail=true
ConnectionStrings__Redis=localhost:6379

# Azurite well-known connection string. Safe to commit — it's the dev-only emulator key.
Blob__AccountUrl=http://127.0.0.1:10000/devstoreaccount1
Blob__PropertyImagesContainer=property-images
Blob__MessageAttachmentsContainer=message-attachments
Blob__FeedCacheContainer=feed-cache
Blob__ConnectionString=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

ServiceBus__Connection=Endpoint=sb://localhost:5672/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true

# ===== External services — stubbed in A0; replace with real test keys before A5/A7 =====
Stripe__SecretKey=sk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me
Stripe__PublishableKey=pk_test_replace_me

# Email — Azure Communication Services (per ADR-0011, replaces SendGrid).
Acs__ConnectionString=
Acs__SenderAddress=donotreply@vrbook.localdev

SignalR__ConnectionString=

# Identity — Microsoft Entra External ID (per ADR-0012, replaces AD B2C).
EntraExternalId__Instance=                            # e.g. https://vrbookcid.ciamlogin.com
EntraExternalId__TenantId=                            # GUID of the External tenant
EntraExternalId__ClientId=                            # vrbook-api app registration id

ApplicationInsights__ConnectionString=

Feed__OutboundTokenPepper=local-dev-not-a-real-secret

# ===== Frontend (read by /web) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Per-flow authority split (ADR-0016): admin = Entra-local only; guest = Entra-local + socials.
# The single NEXT_PUBLIC_ENTRA_AUTHORITY was retired — do not reintroduce it.
NEXT_PUBLIC_ENTRA_AUTHORITY_ADMIN=                    # MSAL authority for the AdminSignUpSignIn user flow
NEXT_PUBLIC_ENTRA_AUTHORITY_GUEST=                    # MSAL authority for the GuestSignUpSignIn user flow
NEXT_PUBLIC_ENTRA_CLIENT_ID=                          # vrbook-web app registration id (different from API's)
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_SIGNALR_NEGOTIATE_URL=http://localhost:8080/api/v1/realtime/negotiate
