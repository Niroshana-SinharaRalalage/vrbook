{
  "consumer": {
    "name": "vrbook-web"
  },
  "interactions": [
    {
      "description": "a guest lists the first page of public properties",
      "providerStates": [
        {
          "name": "a guest can search properties"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v1/properties",
        "query": {
          "limit": [
            "5"
          ]
        }
      },
      "response": {
        "body": {
          "items": [
            {
              "bedrooms": 3,
              "city": "Colombo",
              "country": "LK",
              "currency": "USD",
              "fromNightlyRate": 150,
              "id": "11111111-1111-1111-1111-111111111111",
              "maxGuests": 6,
              "slug": "coastal-villa-p1",
              "title": "Coastal Villa P1",
              "type": "Villa"
            }
          ],
          "nextCursor": "null",
          "total": 5
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].bedrooms": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.items[*].city": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].country": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].currency": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{3}$"
                }
              ]
            },
            "$.items[*].fromNightlyRate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.items[*].maxGuests": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.items[*].slug": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-z0-9\\-]+$"
                }
              ]
            },
            "$.items[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(House|Apartment|Villa|Cottage|Cabin|Studio|Room)$"
                }
              ]
            },
            "$.nextCursor": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "13.2.0"
    },
    "pactRust": {
      "ffi": "0.4.22",
      "models": "1.2.3"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "vrbook-api"
  }
}