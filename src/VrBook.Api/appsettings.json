{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.HttpLogging": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "EntraExternalId": {
    "Instance": "",
    "TenantId": "",
    "ClientId": ""
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "PublishableKey": ""
  },
  "Acs": {
    "ConnectionString": "",
    "SenderAddress": "donotreply@vrbook.example.com"
  },
  "Blob": {
    "AccountUrl": "",
    "PropertyImagesContainer": "property-images",
    "MessageAttachmentsContainer": "message-attachments",
    "FeedCacheContainer": "feed-cache"
  },
  "ServiceBus": {
    "Connection": ""
  },
  "SignalR": {
    "ConnectionString": ""
  },
  "Sync": {
    "DefaultPollIntervalMinutes": 30,
    "StaleAlertHours": 2
  },
  "Booking": {
    "TentativeSlaHours": 24,
    "HoldDurationMinutes": 15
  },
  "Loyalty": {
    "BronzeThreshold": 1,
    "SilverThreshold": 3,
    "GoldThreshold": 6
  },
  "Feed": {
    "OutboundTokenPepper": ""
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Swagger": {
    "EnableInProduction": false
  }
}
