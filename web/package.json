{
  "name": "vrbook-web",
  "version": "0.1.0",
  "private": true,
  "description": "Direct-Booking Vacation Rental Platform — Next.js 14 web app",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:e2e-suite": "node scripts/check-e2e-suite.mjs",
    "test:pact": "vitest run --config tests/pacts/vitest.pact.config.ts",
    "gen:api": "openapi --input ../contracts/openapi.yaml --output ./src/lib/api/generated --client fetch --useOptions --useUnionTypes"
  },
  "dependencies": {
    "@azure/msal-browser": "3.27.0",
    "@azure/msal-react": "2.2.0",
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/sortable": "8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@microsoft/signalr": "8.0.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "@tanstack/react-query": "5.62.0",
    "clsx": "2.1.1",
    "lucide-react": "0.460.0",
    "next": "14.2.18",
    "next-themes": "0.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.53.2",
    "recharts": "2.13.3",
    "tailwind-merge": "2.5.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@pact-foundation/pact": "13.2.0",
    "@playwright/test": "1.49.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.14.0",
    "@typescript-eslint/parser": "8.14.0",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-config-prettier": "9.1.0",
    "jest-axe": "^9.0.0",
    "jsdom": "25.0.1",
    "openapi-typescript-codegen": "0.29.0",
    "postcss": "8.4.49",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "tailwindcss": "3.4.15",
    "typescript": "5.5.4",
    "vitest": "2.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
